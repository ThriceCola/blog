---
import "../styles/global.css";
import type { ImageMetadata } from "astro";
// import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from "../consts";

interface Props {
    title: string;
    description: string;
    image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// const { title, description, image = FallbackImage } = Astro.props;
const { title, description } = Astro.props;
---

<!-- Anti-FOUC: apply theme before first paint -->
<script is:inline>
    (function () {
        const KEY = "theme";
        const DARK = "dark";
        const LIGHT = "light";
        const SYSTEM = "system";

        function resolve(theme) {
            if (theme === DARK) return DARK;
            if (theme === LIGHT) return LIGHT;
            return window.matchMedia("(prefers-color-scheme: dark)").matches
                ? DARK
                : LIGHT;
        }

        const stored = localStorage.getItem(KEY) || SYSTEM;
        const applied = resolve(stored);
        document.documentElement.dataset.theme = applied;

        // Pre-position the theme pill slider before first paint
        const index = stored === DARK ? 1 : stored === SYSTEM ? 2 : 0;
        document.documentElement.style.setProperty(
            "--active-index",
            String(index),
        );

        // Store system listeners so the toggle button can clean them up
        window.__themeSystemQuery = window.matchMedia(
            "(prefers-color-scheme: dark)",
        );
        window.__themeSystemHandler = null;

        if (stored === SYSTEM) {
            const handler = (e) => {
                document.documentElement.dataset.theme = e.matches
                    ? DARK
                    : LIGHT;
            };
            window.__themeSystemQuery.addEventListener("change", handler);
            window.__themeSystemHandler = handler;
        }
    })();
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="256x256" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
    rel="alternate"
    type="application/rss+xml"
    title={SITE_TITLE}
    href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<!-- <meta property="og:image" content={new URL(image.src, Astro.url)} /> -->

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />

<style is:global>
    /* ---- Fast crossfade (LoadingBar handles the visual feedback) ---- */
    ::view-transition-group(*) {
        animation-duration: 0.15s;
        animation-fill-mode: both;
    }
    ::view-transition-old(*) {
        animation-duration: 0.12s;
    }
    ::view-transition-new(*) {
        animation-duration: 0.15s;
    }

    /* Theme toggle: circular reveal from the toggle button */
    [data-theme-transition]::view-transition-old(root),
    [data-theme-transition]::view-transition-new(root) {
        animation: none;
    }
    [data-theme-transition]::view-transition-new(root) {
        animation: theme-reveal 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        z-index: 2;
    }
    [data-theme-transition]::view-transition-old(root) {
        z-index: 1;
    }

    @keyframes theme-reveal {
        from {
            clip-path: circle(0% at var(--reveal-x, 50%) var(--reveal-y, 50%));
        }
        to {
            clip-path: circle(
                150vmax at var(--reveal-x, 50%) var(--reveal-y, 50%)
            );
        }
    }
</style>
