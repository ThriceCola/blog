---
import { Image } from "astro-lqip/components";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import LoadingBar from "../components/LoadingBar.astro";
import { ClientRouter } from "astro:transitions";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, heroImagePosition } = Astro.props;
---

<html lang="zh-CN">
    <head>
        <BaseHead title={title} description={description} />
        <ClientRouter />
        <LoadingBar />
        <style>
            main {
                width: 100%;
                max-width: 720px;
                margin: 0 auto;
                padding: 2em 1em 0;
            }
            .hero-image {
                max-width: 720px;
                width: 100%;
                margin: 0 auto 2em;
                overflow: hidden;
                border: 1px solid var(--semi-accent-color);
                box-shadow: -6px 8px 2px 1px var(--shadow-color);
                line-height: 0;
            }
            .hero-image img {
                display: block;
                width: 100%;
                height: auto;
                aspect-ratio: 720 / 360;
                object-fit: cover;
                filter: blur(15px);
                opacity: 0.75;
                transition: filter 0.5s ease-out, opacity 0.5s ease-out;
                -webkit-mask-image:
                    linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%),
                    linear-gradient(to bottom, transparent 0%, black 4%, black 96%, transparent 100%);
                -webkit-mask-composite: source-in;
                mask-image:
                    linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%),
                    linear-gradient(to bottom, transparent 0%, black 4%, black 96%, transparent 100%);
                mask-composite: intersect;
            }
            .hero-image img.loaded {
                filter: blur(0);
                opacity: 1;
                -webkit-mask-image: none;
                mask-image: none;
            }
            .prose {
                width: 100%;
                max-width: 720px;
                margin: auto;
                padding: 1em;
                color: var(--normal-text-color);
            }
            .title {
                margin-bottom: 1em;
                padding: 1em 0;
                text-align: center;
                line-height: 1.2;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
                font-size: 2em;
            }
            .date {
                margin-bottom: 0.5em;
                color: var(--semi-accent-color);
            }
            .last-updated-on {
                font-style: italic;
                font-size: 0.9em;
            }

            @media (max-width: 720px) {
                main {
                    padding: 1.5em 0.75em 0;
                }
                .title h1 {
                    font-size: 1.5em;
                }
                .prose {
                    padding: 1em 0.5em;
                }
                .hero-image {
                    margin-bottom: 1.25em;
                }
                /*.hero-image img {
					max-height: 280px;
					object-fit: cover;
				}*/
            }

            @media (max-width: 480px) {
                main {
                    padding: 1em 0.5em 0;
                }
                .title {
                    padding: 0.75em 0;
                    margin-bottom: 0.5em;
                }
                .title h1 {
                    font-size: 1.3em;
                }
                .prose {
                    padding: 1em 0.75em;
                }
                .hero-image {
                    margin-bottom: 1em;
                }
                /*.hero-image img {
					max-height: 280px;
					object-fit: cover;
				}*/
            }
        </style>
        <style is:global>
            /* Progressive image blur for markdown content (slotted, needs global) */
            .prose img {
                filter: blur(10px);
                transition: filter 0.5s ease-out;
                background: var(--shadow-color);
            }
            .prose img.loaded {
                filter: blur(0);
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                {
                    heroImage && (
                        <div class="hero-image">
                            <Image
                                src={heroImage}
                                width={720}
                                height={360}
                                alt=""
                                lqip="base64"
                                lqipSize={10}
                                style={{ objectPosition: heroImagePosition }}
                            />
                        </div>
                    )
                }
                <div class="prose">
                    <div class="title">
                        <h1>{title}</h1>
                        <div class="date">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        Last updated on{" "}
                                        <FormattedDate date={updatedDate} />
                                    </div>
                                )
                            }
                        </div>
                        <hr />
                    </div>
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
        <script>
            function initProgressiveImages(selector) {
                document.querySelectorAll(selector).forEach(img => {
                    if (img.complete) {
                        img.classList.add('loaded');
                    } else {
                        img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
                        img.addEventListener('error', () => img.classList.add('loaded'), { once: true });
                    }
                });
            }
            initProgressiveImages('.hero-image img');
            initProgressiveImages('.prose img');
        </script>
    </body>
</html>
