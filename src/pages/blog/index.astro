---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import LoadingBar from "../../components/LoadingBar.astro";
import { ClientRouter } from "astro:transitions";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <ClientRouter />
        <LoadingBar />
        <style>
            main {
                max-width: 960px;
                margin: 0 auto;
            }
            ul {
                display: flex;
                flex-direction: column;
                gap: 1.75rem;
                list-style-type: none;
                margin: 0;
                padding: 0;
            }
            .post-card {
                display: flex;
                gap: 1.5rem;
                text-decoration: none;
                padding: 22px 28px;
            }
            .post-card:hover .post-title {
                color: var(--accent-color);
            }
            .post-image {
                flex-shrink: 0;
                width: 240px;
                height: 140px;
                object-fit: cover;
                border: 1px solid var(--semi-accent-color);
            }
            .post-body {
                display: flex;
                flex-direction: column;
                justify-content: center;
                min-width: 0;
                flex: 1;
            }
            .post-title {
                margin: 0 0 0.35em 0;
                font-size: 1.25em;
                color: var(--normal-text-color);
                line-height: 1.3;
                transition: color 0.2s;
            }
            .post-desc {
                margin: 0 0 0.5em 0;
                color: var(--semi-accent-color);
                font-size: 0.95em;
                line-height: 1.5;
            }
            .post-date {
                margin: 0;
                color: var(--semi-accent-color);
                font-size: 0.85em;
            }
            @media (max-width: 640px) {
                .post-card {
                    flex-direction: column;
                    gap: 0.75rem;
                    padding: 16px 18px;
                }
                .post-image {
                    width: 100%;
                    height: auto;
                    aspect-ratio: 16 / 9;
                    order: -1;
                }
            }

            @media (max-width: 480px) {
                ul {
                    gap: 1.25rem;
                }
                .post-card {
                    padding: 14px 14px;
                }
                .post-title {
                    font-size: 1.1em;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div class="page-header">
                <h1>文章</h1>
                <p>长文放置于此</p>
            </div>

            <section>
                <ul>
                    {
                        posts.map((post) => (
                            <li>
                                <a
                                    href={`/blog/${post.id}/`}
                                    class="post-card card card--hover"
                                >
                                    <div class="post-body">
                                        <h4 class="post-title">
                                            {post.data.title}
                                        </h4>
                                        {post.data.description && (
                                            <p class="post-desc line-clamp-3">
                                                {post.data.description}
                                            </p>
                                        )}
                                        <p class="post-date">
                                            <FormattedDate
                                                date={post.data.pubDate}
                                            />
                                        </p>
                                    </div>
                                    {(() => {
                                                                const cardImgSrc = post.data.cardImage ?? post.data.heroImage;
                                                                const cardImgPos = post.data.cardImage
                                                                    ? post.data.cardImagePosition
                                                                    : post.data.heroImagePosition;
                                                                return cardImgSrc && (
                                                                    <Image
                                                                        class="post-image"
                                                                        width={240}
                                                                        height={140}
                                                                        src={cardImgSrc}
                                                                        alt=""
                                                                        style={{ objectPosition: cardImgPos }}
                                                                    />
                                                                );
                                                            })()}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>
